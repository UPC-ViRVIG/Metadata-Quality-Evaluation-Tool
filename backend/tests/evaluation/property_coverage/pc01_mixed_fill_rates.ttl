@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix dc:      <http://purl.org/dc/elements/1.1/> .
@prefix ex:      <http://example.org/> .

# =============================================================================
# PC-01: Mixed Fill Rates Across Multiple Classes
#
# Purpose: happy path for PropertyCoverageMetric. Two classes with different
# property coverage patterns produce fractional fill rates, a weighted overall
# score, and an ascending-sorted property list per class.
#
# Classes and records:
#   ex:Painting   — 4 records (paint001–paint004)
#   ex:Manuscript — 3 records (ms001–ms003)
#
# ex:Painting properties (rdf:type excluded):
#   dc:title    → 4/4 records → fill_rate 1.0000
#   dc:creator  → 3/4 records → fill_rate 0.7500
#   dc:date     → 2/4 records → fill_rate 0.5000
#   dc:subject  → 1/4 records → fill_rate 0.2500
#   (dc:format intentionally absent from every record → never enters prop_counts)
#
# ex:Painting score = mean(1.0, 0.75, 0.5, 0.25) = 0.6250
#
# ex:Manuscript properties:
#   dc:title    → 3/3 records → fill_rate 1.0000
#   dc:creator  → 3/3 records → fill_rate 1.0000
#   dc:date     → 2/3 records → fill_rate 0.6667
#   dc:language → 1/3 records → fill_rate 0.3333
#
# ex:Manuscript score = mean(1.0, 1.0, 0.6667, 0.3333) = 0.7500
#
# Overall score = (0.6250×4 + 0.7500×3) / (4+3) = 4.75 / 7 = 0.6786
# =============================================================================

# ── ex:Painting records ───────────────────────────────────────────────────────

# paint001 — dc:title, dc:creator, dc:date, dc:subject
ex:paint001
    rdf:type     ex:Painting ;
    dc:title     "The Night Watch"@en ;
    dc:creator   "Rembrandt van Rijn" ;
    dc:date      "1642" ;
    dc:subject   "Military" .

# paint002 — dc:title, dc:creator, dc:date
ex:paint002
    rdf:type     ex:Painting ;
    dc:title     "Girl with a Pearl Earring"@en ;
    dc:creator   "Johannes Vermeer" ;
    dc:date      "1665" .

# paint003 — dc:title, dc:creator only
ex:paint003
    rdf:type     ex:Painting ;
    dc:title     "The Milkmaid"@en ;
    dc:creator   "Johannes Vermeer" .

# paint004 — dc:title only
ex:paint004
    rdf:type     ex:Painting ;
    dc:title     "The Anatomy Lesson"@en .

# ── ex:Manuscript records ─────────────────────────────────────────────────────

# ms001 — dc:title, dc:creator, dc:date, dc:language
ex:ms001
    rdf:type      ex:Manuscript ;
    dc:title      "Codex Argenteus"@en ;
    dc:creator    "Unknown Scribe" ;
    dc:date       "520" ;
    dc:language   "got" .

# ms002 — dc:title, dc:creator, dc:date
ex:ms002
    rdf:type      ex:Manuscript ;
    dc:title      "Book of Kells"@en ;
    dc:creator    "Columban Monks" ;
    dc:date       "800" .

# ms003 — dc:title, dc:creator only
ex:ms003
    rdf:type      ex:Manuscript ;
    dc:title      "Lindisfarne Gospels"@en ;
    dc:creator    "Eadfrith of Lindisfarne" .
